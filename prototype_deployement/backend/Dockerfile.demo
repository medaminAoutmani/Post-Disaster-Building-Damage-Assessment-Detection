FROM python:3.11-slim

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV RAG_PDF_DIR=/app/pdf_rag
ENV RAG_AUTO_INDEX_LOCAL_PDFS=true

COPY requirements-demo.txt .
RUN pip install --no-cache-dir --timeout 1000 --retries 10 -r requirements-demo.txt

COPY app/ ./app/

EXPOSE 8000
CMD ["uvicorn", "app.demo_main:app", "--host", "0.0.0.0", "--port", "8000"]
